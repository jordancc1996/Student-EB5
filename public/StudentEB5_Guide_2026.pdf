    <style>
      /* ==========================================================================
         StudentEB5 Pre-render Styles - Matching React Design System
         ========================================================================== */
      
      /* CSS Variables matching React app's design tokens */
      :root {
        --background: hsl(0, 0%, 100%);
        --foreground: hsl(0, 0%, 15%);
        --hero-dark: hsl(0, 0%, 20%);
        --hero-foreground: hsl(0, 0%, 95%);
        --primary: hsl(0, 0%, 15%);
        --primary-foreground: hsl(0, 0%, 95%);
        --secondary: hsl(0, 0%, 96%);
        --muted: hsl(0, 0%, 94%);
        --muted-foreground: hsl(0, 0%, 45%);
        --border: hsl(0, 0%, 90%);
        --card: hsl(0, 0%, 100%);
        --radius: 0.25rem;
        --shadow-soft: 0 2px 10px -2px rgba(0, 0, 0, 0.1);
        --shadow-medium: 0 4px 20px -5px rgba(0, 0, 0, 0.15);
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
      }
      
      /* Base Styles */
      * { box-sizing: border-box; }
      
      body { 
        margin: 0; 
        font-family: var(--font-sans);
        line-height: 1.6; 
        color: var(--foreground);
        background: var(--background);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-serif);
        font-weight: 400;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }
      
      /* ==========================================================================
         Loading Overlay - Smooth transition to React
         ========================================================================== */
      #loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--background);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        transition: opacity 0.4s ease-out;
        pointer-events: none;
      }
      
      .loading-content {
        text-align: center;
      }
      
      .loading-logo {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 500;
        color: var(--foreground);
        letter-spacing: 0.02em;
        margin-bottom: 1rem;
      }
      
      .loading-spinner {
        width: 24px;
        height: 24px;
        border: 2px solid var(--border);
        border-top-color: var(--foreground);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto;
      }
      
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      
      /* Hide overlay when JS loads */
      .js-loaded #loading-overlay {
        opacity: 0;
      }
      
      /* ==========================================================================
         SEO Fallback Content - Visible to crawlers, hidden when React loads
         ========================================================================== */
      .seo-fallback { 
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 20px;
        opacity: 1;
        transition: opacity 0.3s ease-out;
      }
      
      .seo-fallback a { 
        color: var(--foreground); 
        text-decoration: none;
        transition: opacity 0.2s ease;
      }
      
      .seo-fallback a:hover { 
        opacity: 0.7;
      }
      
      /* Navigation - Matching React Header */
      .seo-nav { 
        display: flex; 
        flex-wrap: wrap; 
        gap: 24px; 
        justify-content: center; 
        padding: 24px 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: 40px;
      }
      
      .seo-nav a { 
        color: var(--foreground);
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 1rem;
        opacity: 0.8;
        transition: opacity 0.2s ease;
      }
      
      .seo-nav a:hover {
        opacity: 1;
      }
      
      /* Hero Section - Matching React hero-section */
      .seo-hero { 
        text-align: center; 
        padding: 80px 24px;
        background-color: var(--hero-dark);
        color: var(--hero-foreground);
        margin-bottom: 60px;
        border-radius: var(--radius);
      }
      
      .seo-hero h1 { 
        font-family: var(--font-serif);
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 400;
        margin: 0 0 24px;
        line-height: 1.1;
        letter-spacing: -0.02em;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
      }
      
      .seo-hero p { 
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        opacity: 0.9;
        margin: 16px auto;
        max-width: 700px;
        letter-spacing: 0.02em;
      }
      
      .seo-hero .hero-location {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 500;
        font-style: normal;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        opacity: 0.8;
        margin-bottom: 8px;
      }
      
      /* CTA Buttons - Matching React button styles */
      .seo-cta { 
        display: inline-block; 
        padding: 14px 32px;
        background: var(--primary-foreground);
        color: var(--primary) !important;
        border-radius: var(--radius);
        margin: 12px 8px;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 1rem;
        letter-spacing: 0.02em;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
      }
      
      .seo-cta:hover { 
        transform: translateY(-2px);
        box-shadow: var(--shadow-medium);
        text-decoration: none !important;
        opacity: 1;
      }
      
      .seo-cta-secondary {
        background: transparent;
        color: var(--hero-foreground) !important;
        border: 1px solid rgba(255, 255, 255, 0.3);
      }
      
      .seo-cta-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
      }
      
      /* Content Sections - Matching React section styles */
      .seo-section { 
        margin-bottom: 60px;
        padding: 0 24px;
      }
      
      .seo-section h2 { 
        font-family: var(--font-serif);
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 400;
        color: var(--foreground);
        margin-bottom: 24px;
        letter-spacing: -0.02em;
      }
      
      .seo-section p { 
        font-family: var(--font-sans);
        line-height: 1.8;
        color: var(--foreground);
        margin-bottom: 20px;
        font-size: 1.05rem;
        font-weight: 400;
      }
      
      /* Card Grid - Matching React Card component */
      .seo-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
        gap: 24px;
      }
      
      .seo-card { 
        padding: 28px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--card);
        transition: box-shadow 0.3s ease, transform 0.3s ease;
      }
      
      .seo-card:hover { 
        box-shadow: var(--shadow-medium);
        transform: translateY(-4px);
      }
      
      .seo-card h3 { 
        font-family: var(--font-serif);
        margin: 0 0 12px;
        font-size: 1.25rem;
        font-weight: 500;
      }
      
      .seo-card h3 a { 
        color: var(--foreground);
      }
      
      .seo-card p { 
        margin: 0;
        font-size: 0.95rem;
        color: var(--muted-foreground);
        line-height: 1.7;
      }
      
      /* Footer - Matching React Footer */
      .seo-footer { 
        border-top: 1px solid var(--border);
        padding: 48px 24px 32px;
        margin-top: 60px;
        background: var(--secondary);
      }
      
      .seo-footer-inner { 
        max-width: 1200px; 
        margin: 0 auto;
      }
      
      .seo-footer-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
        gap: 40px;
      }
      
      .seo-footer h4 { 
        font-family: var(--font-serif);
        margin: 0 0 20px;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--foreground);
      }
      
      .seo-footer nav { 
        display: flex; 
        flex-direction: column; 
        gap: 12px;
      }
      
      .seo-footer a { 
        color: var(--muted-foreground) !important;
        font-size: 0.95rem;
        transition: color 0.2s ease;
      }
      
      .seo-footer a:hover { 
        color: var(--foreground) !important;
        opacity: 1;
      }
      
      /* Highlight Section - CTA blocks */
      .seo-highlight { 
        background: var(--hero-dark);
        color: var(--hero-foreground);
        padding: 60px 32px;
        border-radius: var(--radius);
        text-align: center;
        margin: 48px 0;
      }
      
      .seo-highlight h2 { 
        color: var(--hero-foreground);
        margin-bottom: 16px;
      }
      
      .seo-highlight p { 
        color: rgba(255, 255, 255, 0.7);
        max-width: 600px;
        margin: 0 auto 28px;
      }
      
      /* Hide SEO content when React loads */
      .js-loaded .seo-fallback { 
        display: none !important;
      }
      
      /* Responsive adjustments */
      @media (max-width: 768px) {
        .seo-nav {
          gap: 16px;
          padding: 16px 0;
        }
        
        .seo-nav a {
          font-size: 0.9rem;
        }
        
        .seo-hero {
          padding: 60px 20px;
        }
        
        .seo-grid {
          grid-template-columns: 1fr;
        }
        
        .seo-footer-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
