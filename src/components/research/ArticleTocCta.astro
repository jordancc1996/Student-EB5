---
import { resolveTocCta } from '@/lib/research/tocCta';

interface Props {
  category?: string;
  standalone?: boolean;
}

const { category, standalone = false } = Astro.props;
const cta = resolveTocCta(category);
---

<div
  class:list={[
    'article-contents__cta',
    standalone && 'article-contents__cta--standalone',
  ]}
>
  <a
    href={cta.href}
    class="article-contents__cta-link"
    data-toc-cta
    data-toc-category={category ?? ''}
  >
    {cta.label}
  </a>
</div>
