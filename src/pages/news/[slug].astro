---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import Eb5LandscapeMay2026Body from '@/components/news/Eb5LandscapeMay2026Body';
import UscisAdjustmentMemoBody from '@/components/news/UscisAdjustmentMemoBody';
import JulyBulletinQ3Body from '@/components/news/JulyBulletinQ3Body';
import NewsArticleLayout from '@/components/news/NewsArticleLayout.astro';
import { getNewsArticle, newsArticleSlugs } from '@/data/newsArticles';
import { getNewsFaqSchema } from '@/data/newsFaqSchemas';
import { getNewsTocItems } from '@/lib/news/newsArticleHeadings';
import { SITE_CONFIG } from '@/lib/seo/config';
import { generateArticleSchema } from '@/lib/seo/structured-data';

export const getStaticPaths: GetStaticPaths = () =>
  newsArticleSlugs.map((slug) => ({
    params: { slug },
  }));

const { slug } = Astro.params;

if (!slug) {
  throw new Error('News article slug is required');
}

const article = getNewsArticle(slug);

if (!article) {
  throw new Error(`Unknown news article slug: ${slug}`);
}

const pageCanonical = `${SITE_CONFIG.url}/news/${slug}`;
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const tocItems = getNewsTocItems(slug, article.tocLabels);

const articleSchema = {
  ...generateArticleSchema({
    headline: article.title,
    description: article.metaDescription,
    image: ogImage,
    datePublished: article.datePublished,
    dateModified: article.datePublished,
    author: 'StudentEB5',
    keywords: article.schemaKeywords,
  }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageCanonical,
  },
};

const faqSchema = getNewsFaqSchema(slug);
const structuredData = faqSchema ? [articleSchema, faqSchema] : [articleSchema];
---

<Layout>
  <Fragment slot="head">
    <title>{article.metaTitle}</title>
    <meta name="description" content={article.metaDescription} />
    <meta name="keywords" content={article.keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={article.title} />
    <meta property="og:description" content={article.metaDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={article.title} />
    <meta name="twitter:description" content={article.metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
    ))}
  </Fragment>

  <div class="min-h-screen bg-background research-article-page">
    <Header client:load />
    <NewsArticleLayout article={article} tocItems={tocItems}>
      {
        slug === 'eb5-visa-landscape-news-update-may-2026' ? (
          <Eb5LandscapeMay2026Body />
        ) : slug === 'uscis-adjustment-of-status-memo-eb5-investors' ? (
          <UscisAdjustmentMemoBody />
        ) : (
          <JulyBulletinQ3Body />
        )
      }
    </NewsArticleLayout>
    <ConsultationCTA client:visible />
    <Footer client:visible />
    <Toaster client:load />
  </div>
</Layout>
