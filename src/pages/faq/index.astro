---
import Layout from '../../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import Breadcrumb from '@/components/Breadcrumb';
import LegalDisclaimer from '@/components/LegalDisclaimer.astro';
import OptimizedImage from '@/components/OptimizedImage.astro';
import FaqListing from '@/components/FaqListing';
import JourneyCTA from '@/components/JourneyCTA';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import { getCollection } from 'astro:content';
import faqHero from '@/assets/faq-hero.jpg';
import faqHeroWebp from '@/assets/faq-hero.webp';
import { SITE_CONFIG } from '@/lib/seo/config';
import { generateFAQSchema } from '@/lib/seo/structured-data';

const faqEntries = await getCollection('faq');

const faqListingItems = faqEntries.map((entry) => ({
  id: entry.data.id,
  slug: entry.data.slug,
  question: entry.data.question,
  answer: entry.body ?? '',
  category: entry.data.category,
  keywords: entry.data.keywords,
}));

const faqSchemaItems = faqEntries.map((entry) => ({
  question: entry.data.question,
  answer: (entry.body ?? '').replace(/<[^>]*>/g, ''),
}));

const title = 'EB-5 FAQ: H-1B Grace Period, Rural EB-5, Concurrent Filing & Gifted Funds | StudentEB5';
const description =
  'Answers to top EB-5 questions: Can H-1B holders self-sponsor? How does concurrent filing work? Can parents gift EB-5 funds? Rural EB-5 for Indians.';
const pageCanonical = `${SITE_CONFIG.url}/faq`;
const ogTitle = 'EB-5 Visa FAQ: Your Top Immigration Questions Answered';
const ogDescription =
  'Find clear answers to common EB-5 questions about $800K investment requirements, 2-3 year processing timelines, family eligibility, and how students and H-1B holders qualify for permanent residency.';
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'EB-5 FAQ',
  'EB-5 investment cost',
  'EB-5 timeline',
  'EB-5 eligibility',
  'student visa green card',
  'H-1B to EB-5',
];

const structuredData = generateFAQSchema(faqSchemaItems);
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header client:load />

    <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center -mt-[120px] pt-[120px]">
      <div class="absolute inset-0">
        <OptimizedImage
          src={faqHero}
          webpSrc={faqHeroWebp}
          alt="San Francisco downtown and Ferry Building at sunset representing opportunity"
          className="w-full h-full object-cover"
          loading="eager"
          fetchPriority="high"
          sizes="100vw"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/60"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 max-w-4xl mx-auto leading-tight">
          Frequently Asked Questions About EB-5 Visas for Students
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Everything you need to know about the EB-5 visa program. Can't find what you're looking for?
          Explore our resources or contact us for personalized assistance.
        </p>
      </div>
    </section>

    <main class="container mx-auto px-6 pt-4 pb-8">
      <Breadcrumb client:load initialPathname="/faq" />
      <LegalDisclaimer className="max-w-6xl mx-auto mb-6" />
      <FaqListing client:load faqs={faqListingItems} />
    </main>

    <ConsultationCTA client:visible />
    <JourneyCTA client:visible />
    <Footer client:visible />
    <Toaster client:load />
  </div>
</Layout>
