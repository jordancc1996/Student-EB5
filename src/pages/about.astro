---
import Layout from '../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import Breadcrumb from '@/components/Breadcrumb';
import AboutMainContent from '@/components/AboutMainContent';
import JourneyCTA from '@/components/JourneyCTA.astro';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import OptimizedImage from '@/components/OptimizedImage.astro';
import aboutHeroNew from '@/assets/about-hero-new.jpg';
import aboutHeroNewWebp from '@/assets/about-hero-new.webp';
import { SITE_CONFIG } from '@/lib/seo/config';
import { generateAboutPageSchema } from '@/lib/seo/structured-data';

const title = 'Best EB-5 Consultants & Advisors for Indian Engineers';
const description =
  'Best EB-5 consultant and elite EB-5 immigration advisors. Premier path for Indian software engineers seeking permanent residency without sponsorship.';
const pageCanonical = `${SITE_CONFIG.url}/about`;
const ogTitle = 'Best EB-5 Consultants & Advisors for Indian Engineers';
const ogDescription =
  'Best EB-5 consultant and elite EB-5 immigration advisors. Premier path for Indian software engineers seeking permanent residency without sponsorship.';
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'best eb5 consultant',
  'eb5 immigration advisors',
  'best immigration path for indian software engineers',
  'permanent residency without sponsorship',
];

const structuredData = generateAboutPageSchema();
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header client:load />

    <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center -mt-[120px] pt-[120px]">
      <div class="absolute inset-0">
        <OptimizedImage
          src={aboutHeroNew}
          webpSrc={aboutHeroNewWebp}
          alt="Golden Gate Bridge tower representing the gateway to American opportunity"
          className="w-full h-full object-cover"
          loading="eager"
          fetchPriority="high"
          sizes="100vw"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/60"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 max-w-4xl mx-auto leading-tight">
          About StudentEB5: The Premier EB-5 Visa Guide for Students & Professionals
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Your dedicated educational resource for F-1 international students and H-1B professionals navigating
          the EB-5 immigrant investor program. We help you explore strategies to secure US Permanent Residency
          (Green Card) through investment.
        </p>
      </div>
    </section>

    <main class="container mx-auto px-6 pt-4 pb-8">
      <Breadcrumb client:load initialPathname="/about" />
      <AboutMainContent />
    </main>

    <ConsultationCTA client:visible />
    <JourneyCTA />
    <Footer client:visible />
    <Toaster client:load />
  </div>
</Layout>
