---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import LegalDisclaimer from '@/components/LegalDisclaimer.astro';
import OptimizedImage from '@/components/OptimizedImage.astro';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import ShareButtons from '@/components/ShareButtons';
import MidArticleCTA from '@/components/MidArticleCTA';
import { SITE_CONFIG } from '@/lib/seo/config';
import { generateArticleSchema } from '@/lib/seo/structured-data';
import {
  splitArticleContent,
  resolveAbsoluteAssetUrl,
} from '@/lib/research/renderArticleContent';
import { extractArticleH2s, buildTocItems } from '@/lib/research/articleHeadings';
import ArticleContents from '@/components/research/ArticleContents.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
};

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const post = entry.data;
const slug = post.slug;

if (!entry.body) {
  throw new Error(`Blog entry missing body: ${slug}`);
}

const hasHero = !!post.heroImage;
const pageCanonical = `${SITE_CONFIG.url}/research/${slug}`;
const metaTitle = post.metaTitle.includes('StudentEB5')
  ? post.metaTitle
  : `${post.metaTitle} | StudentEB5`;
const ogImage = resolveAbsoluteAssetUrl(post.image, SITE_CONFIG.url);

const articleSchema = {
  ...generateArticleSchema({
    headline: post.title,
    description: post.metaDescription,
    image: resolveAbsoluteAssetUrl(post.image, SITE_CONFIG.url),
    datePublished: post.date,
    dateModified: post.updatedDate || post.date,
    author: post.author,
    keywords: post.keywords.join(', '),
  }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageCanonical,
  },
};

const { firstHalfHtml, secondHalfHtml, showMidSplit } = splitArticleContent(entry.body);

const tocItems = buildTocItems(extractArticleH2s(entry.body), post.tocLabels);

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.data.slug !== slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)
  .map((p) => p.data);
---

<Layout>
  <Fragment slot="head">
    <title>{metaTitle}</title>
    <meta name="description" content={post.metaDescription} />
    <meta name="keywords" content={post.keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={post.metaTitle} />
    <meta property="og:description" content={post.metaDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={post.metaTitle} />
    <meta name="twitter:description" content={post.metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
  </Fragment>

  <div class="min-h-screen bg-background research-article-page">
    <Header client:load />

    {
      hasHero && post.heroImage && (
        <section class="relative -mt-[120px] pt-[120px] min-h-[60vh] flex items-center justify-center overflow-hidden">
          <OptimizedImage
            src={post.heroImage}
            alt={post.imageAlt}
            className="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            fetchPriority="high"
            sizes="100vw"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/60"></div>
          <div class="relative z-10 container mx-auto px-6 py-16 text-center text-white max-w-4xl">
            <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80 mb-4 bg-white/20 text-white border-white/30">
              {post.category}
            </div>
            <h1 class="research-article-title font-serif font-bold mb-6 drop-shadow-lg">
              {post.title}
            </h1>
            <div class="research-article-meta flex flex-wrap items-center justify-center gap-6 text-white/90 font-medium">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                <span>Published {post.date}</span>
              </div>
              {
                post.updatedDate && post.updatedDate !== post.date && (
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                    <span>Updated {post.updatedDate}</span>
                  </div>
                )
              }
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{post.readTime}</span>
              </div>
            </div>
          </div>
        </section>
      )
    }

    <main class="pt-4 pb-8">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <!-- Breadcrumb & Back Navigation -->
          <nav aria-label="Breadcrumb" class="py-4 mb-6">
            <ol class="flex flex-wrap items-center gap-0 text-sm">
              <li class="flex items-center">
                <a href="/" class="text-muted-foreground/70 hover:text-foreground transition-colors font-medium tracking-wide uppercase text-[11px]">
                  Home
                </a>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 mx-2 text-muted-foreground/30" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </li>
              <li class="flex items-center">
                <a href="/research" class="text-muted-foreground/70 hover:text-foreground transition-colors font-medium tracking-wide uppercase text-[11px] inline-flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                  Research
                </a>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 mx-2 text-muted-foreground/30" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </li>
              <li class="flex items-center">
                <span class="text-foreground font-serif text-base font-semibold">{post.title}</span>
              </li>
            </ol>
          </nav>

          {
            !hasHero && (
              <header class="mb-8">
                <div class="flex flex-wrap items-center gap-4 mb-4">
                  <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80">
                    {post.category}
                  </div>
                  <div class="research-article-meta flex items-center gap-2 text-muted-foreground font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                    <span>Published {post.date}</span>
                  </div>
                  {
                    post.updatedDate && post.updatedDate !== post.date && (
                      <div class="research-article-meta flex items-center gap-2 text-muted-foreground font-medium">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                        <span>Updated {post.updatedDate}</span>
                      </div>
                    )
                  }
                  <div class="research-article-meta flex items-center gap-2 text-muted-foreground font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>{post.readTime}</span>
                  </div>
                </div>

                <h1 class="research-article-title font-serif font-bold mb-6">
                  {post.title}
                </h1>

                <div class="aspect-video overflow-hidden rounded-lg mb-8">
                  <OptimizedImage
                    src={post.image}
                    alt={post.imageAlt}
                    title={post.title}
                    className="w-full h-full object-cover"
                    loading="eager"
                    fetchPriority="high"
                    sizes="(max-width: 768px) 100vw, 880px"
                  />
                </div>
              </header>
            )
          }

          <ArticleContents items={tocItems} category={post.category} />

          <article>
            <LegalDisclaimer className="mb-8 article-legal-disclaimer" />
            <div class="article-content" set:html={firstHalfHtml} />
            {showMidSplit && <MidArticleCTA client:visible category={post.category} />}
            {secondHalfHtml && <div class="article-content" set:html={secondHalfHtml} />}
          </article>

          <!-- Disclaimer -->
          <div class="mt-12 p-6 bg-muted/50 border border-border rounded-lg max-w-[42rem] mx-auto">
            <p class="article-bottom-disclaimer text-muted-foreground leading-relaxed m-0">
              <strong class="text-foreground">Disclaimer:</strong> The opinions expressed on this website are solely those of the author/presenter. The information provided is for general informational purposes only and should not be considered professional or legal advice. Student EB5 and its contributors do not endorse or take responsibility for any actions taken based on the information presented here. Visitors are strongly advised to consult with qualified immigration attorneys and financial advisors before making any EB-5 investment decisions or taking any actions based on the content on this website.
            </p>
          </div>

          <ShareButtons
            client:visible
            url={pageCanonical}
            title={post.title}
            excerpt={post.excerpt}
          />

          <!-- Article Footer -->
          <footer class="mt-12 pt-8 border-t">
            <div class="flex items-center justify-between">
              <div class="article-footer-meta text-muted-foreground">
                Published {post.date}{post.updatedDate && post.updatedDate !== post.date ? ` · Updated ${post.updatedDate}` : ''}
              </div>
              <a
                href="/contact"
                class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                Learn More
              </a>
            </div>
          </footer>

          <!-- Related Articles Section -->
          <section class="mt-16 pt-8 border-t">
            <h2 class="text-2xl font-serif font-bold mb-8">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {
                relatedPosts.map((relatedPost) => (
                  <div class="rounded-lg border bg-card text-card-foreground shadow-sm overflow-hidden hover:shadow-lg transition-shadow">
                    <a href={`/research/${relatedPost.slug}`}>
                      <div class="aspect-video overflow-hidden">
                        <OptimizedImage
                          src={relatedPost.image}
                          alt={relatedPost.imageAlt}
                          className="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                          loading="lazy"
                          sizes="(max-width: 768px) 100vw, 33vw"
                        />
                      </div>
                      <div class="p-4">
                        <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80 mb-2">
                          {relatedPost.category}
                        </div>
                        <h3 class="font-serif font-bold text-lg mb-2 line-clamp-2 hover:text-primary transition-colors">
                          {relatedPost.title}
                        </h3>
                        <div class="flex items-center justify-between text-sm text-muted-foreground">
                          <span>{relatedPost.date}</span>
                          <span>{relatedPost.readTime}</span>
                        </div>
                      </div>
                    </a>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </main>
    <ConsultationCTA client:visible articleForm />
    <Footer client:visible />
  </div>
  <Toaster client:load />
</Layout>
