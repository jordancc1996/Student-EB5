---
import Layout from '../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import Breadcrumb from '@/components/Breadcrumb';
import StudentPlaybookMainContent from '@/components/StudentPlaybookMainContent';
import JourneyCTA from '@/components/JourneyCTA.astro';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import { SITE_CONFIG } from '@/lib/seo/config';
import { generateWebPageSchema } from '@/lib/seo/structured-data';

const title = 'F-1 to EB-5: Best Visa Pathway & Avoid H-1B Lottery';
const description =
  'F-1 to EB-5 strategy to avoid the H-1B lottery, the best visa pathway after F-1, how Indian students can stay in America permanently, and parent-gifted EB-5 funds.';
const pageCanonical = `${SITE_CONFIG.url}/student-playbook`;
const ogTitle = 'F-1 to EB-5: Best Visa Pathway & Avoid H-1B Lottery';
const ogDescription =
  'Premium guidance on F-1 to EB-5, avoiding the H-1B lottery, how Indian students can stay in America permanently, and whether parents can gift EB-5 funds.';
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'f1 to eb5',
  'avoid h1b lottery through eb5',
  'best visa pathway after f1',
  'how indian students can stay in america permanently',
  'can parents gift eb5 funds',
];

const breadcrumbs = [
  { name: 'Home', url: SITE_CONFIG.url },
  { name: 'Resources', url: `${SITE_CONFIG.url}/resources` },
  { name: 'Student Playbook', url: `${SITE_CONFIG.url}/student-playbook` },
];

const structuredData = generateWebPageSchema(
  'F-1 to EB-5: Best Visa Pathway & Avoid H-1B Lottery',
  'Expert guidance on F-1 to EB-5, avoiding the H-1B lottery, the best visa pathway after F-1, and how Indian students can stay in America permanently.',
  `${SITE_CONFIG.url}/student-playbook`,
  breadcrumbs
);
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
  </Fragment>

  <div class="min-h-screen bg-gradient-to-br from-background to-secondary/20">
    <Header client:load />

    <main class="container mx-auto px-6 py-8">
      <Breadcrumb client:load initialPathname="/student-playbook" />
      <StudentPlaybookMainContent />
    </main>

    <ConsultationCTA client:visible />
    <JourneyCTA />
    <Footer client:visible />
    <Toaster client:load />
  </div>
</Layout>
