---
import Layout from '../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import Breadcrumb from '@/components/Breadcrumb';
import NewsMainContent from '@/components/NewsMainContent';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import { SITE_CONFIG } from '@/lib/seo/config';
import { newsArticles } from '@/data/newsArticles';
import newsHero from '@/assets/news-hero.jpg';

const title = 'EB-5 News & Policy Updates: USCIS, Visa Bulletin, Legislation';
const description =
  'Breaking EB-5 immigration news, USCIS policy updates, visa bulletin movement, regional center notices, and legislative developments for investors.';
const pageCanonical = `${SITE_CONFIG.url}/news`;
const ogTitle = 'EB-5 Immigration News & Updates';
const ogDescription =
  'Stay current with the latest EB-5 policy updates, USCIS announcements, visa bulletin movement, and legislative developments affecting investors and regional centers.';
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'EB-5 news',
  'USCIS news',
  'visa bulletin',
  'EB-5 policy update',
  'EB-5 legislation',
  'regional center news',
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'EB-5 News & Policy Updates',
    url: pageCanonical,
    description: 'Breaking EB-5 immigration news, USCIS policy updates, visa bulletin movement, and legislative developments.',
    isPartOf: { '@type': 'WebSite', name: SITE_CONFIG.name, url: SITE_CONFIG.url },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: newsArticles.map((article, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `${SITE_CONFIG.url}${article.href}`,
        name: article.title,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.url },
      { '@type': 'ListItem', position: 2, name: 'News', item: pageCanonical },
    ],
  },
];
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
    ))}
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header client:load />

    <section class="relative h-[55vh] min-h-[450px] flex items-center justify-center -mt-[120px] pt-[120px]">
      <div class="absolute inset-0">
        <img
          src={newsHero.src}
          alt="New York City skyline at dusk representing EB-5 immigration news and policy updates"
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/60"></div>
      </div>

      <div class="relative z-10 container mx-auto px-6 text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white mb-6 drop-shadow-lg">
          EB-5 Immigration News & Updates
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-3xl mx-auto drop-shadow">
          Breaking news, policy updates, and regulatory changes for the EB-5 Immigrant Investor Program. Stay current with the latest developments affecting investors, regional centers, and immigration policy.
        </p>
      </div>
    </section>

    <main class="container mx-auto px-6 pt-4 pb-12">
      <Breadcrumb client:load initialPathname="/news" />
      <NewsMainContent />
    </main>

    <ConsultationCTA client:visible />
    <Footer client:visible />
    <Toaster client:load />
  </div>
</Layout>
