---
import Layout from '../../layouts/Layout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import Breadcrumb from '@/components/Breadcrumb';
import ConcurrentFilingCheckerMainContent from '@/components/ConcurrentFilingCheckerMainContent';
import { SITE_CONFIG } from '@/lib/seo/config';

const title = 'EB-5 Concurrent Filing Eligibility Checker | StudentEB5';
const description =
  'Check your EB-5 concurrent filing eligibility. See if you can file I-526E and I-485 together to secure your EAD work permit and Advance Parole travel.';
const pageCanonical = `${SITE_CONFIG.url}/tools/eb5-concurrent-filing-eligibility`;
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'EB-5 concurrent filing eligibility',
  'Concurrent filing I-485',
  'I-526E',
  'EAD EB-5',
  'Advance Parole EB-5',
];
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header client:load />

    <section class="relative -mt-[120px] pt-[120px] bg-slate-900">
      <div class="container mx-auto px-4 py-6">
        <Breadcrumb
          client:load
          customTitle="EB-5 Concurrent Filing Eligibility"
          variant="dark"
          initialPathname="/tools/eb5-concurrent-filing-eligibility"
        />
      </div>
    </section>

    <ConcurrentFilingCheckerMainContent client:load />

    <Footer client:visible />
  </div>
</Layout>
