---
import Layout from '../layouts/Layout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import IntroSection from '@/components/sections/IntroSection.astro';
import PhilosophySection from '@/components/sections/PhilosophySection.astro';
import BenefitsSection from '@/components/sections/BenefitsSection.astro';
import PartnerCredibility from '@/components/sections/PartnerCredibility.astro';
import CallToActionSection from '@/components/sections/CallToActionSection.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import { ConsultationCTA } from '@/components/ConsultationCTA';
import { Toaster } from '@/components/ui/toaster';
import { SITE_CONFIG } from '@/lib/seo/config';
import {
  generateOrganizationSchema,
  generateWebsiteSchema,
  generateProfessionalServiceSchema,
  generateSiteNavigationSchema,
} from '@/lib/seo/structured-data';

const title = 'EB-5 Green Card for H-1B & F-1 Students | StudentEB5';
const description =
  'EB-5 for H-1B holders: green card without employer sponsorship via rural EB-5. Avoid the H-1B lottery. Exclusive permanent residency without sponsorship.';
const rawCanonical = `${SITE_CONFIG.url}/`;
const pageCanonical = rawCanonical.replace(/\/+$/, '') || rawCanonical;
const ogTitle = 'EB-5 Investment Visa: Your Path from Student to Green Card Holder';
const ogDescription =
  'Discover how international students transform F-1 visas into permanent US residency through EB-5 investment. Expert guidance, tools, and step-by-step resources for students and H-1B professionals seeking green cards.';
const ogImage = `${SITE_CONFIG.url}/og-image.jpg`;
const keywords = [
  'EB-5 visa',
  'international students',
  'F-1 to green card',
  'H-1B alternative',
  'investment immigration',
  '$800K EB-5',
  'permanent residency',
];

const structuredData = [
  generateOrganizationSchema(),
  generateWebsiteSchema(),
  generateProfessionalServiceSchema(),
  generateSiteNavigationSchema(),
];
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data).replace(/https:\/\/www\.studenteb5\.com/g, SITE_CONFIG.url)} />
    ))}
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header client:load />
    <main>
      <HeroSection />
      <IntroSection />
      <PhilosophySection />
      <BenefitsSection />
      <PartnerCredibility />
      <ConsultationCTA client:visible />
      <CallToActionSection />
    </main>
    <Footer client:visible />
  </div>
  <Toaster client:load />
</Layout>
